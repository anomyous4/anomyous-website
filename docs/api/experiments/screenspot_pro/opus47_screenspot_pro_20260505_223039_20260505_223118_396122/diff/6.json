{"iteration":6,"prev_iteration":5,"diffs":[{"filename":"predict.py","status":"modified","added_lines":39,"removed_lines":14,"diff":"--- a/predict.py\n+++ b/predict.py\n@@ -1,4 +1,4 @@\n-import os, sys, json, argparse, re\n\n+import os, sys, json, argparse, re, math\n\n import torch\n\n from PIL import Image\n\n from transformers import Qwen2_5_VLForConditionalGeneration, AutoProcessor\n\n@@ -6,21 +6,38 @@\n DEFAULT_MODEL_PATH = '/data/base_model/Qwen2.5-VL-3B-Instruct'\n\n \n\n \n\n-def parse_coords(text, w, h):\n\n-    \"\"\"Parse coordinates from model output. Returns (bbox, point) where each is None or list.\"\"\"\n\n+def smart_resize(h, w, factor=28, min_pixels=256*28*28, max_pixels=1280*28*28):\n\n+    # Mirrors qwen_vl_utils smart_resize.\n\n+    if max(h, w) / min(h, w) > 200:\n\n+        raise ValueError('aspect ratio too large')\n\n+    h_bar = max(factor, round(h / factor) * factor)\n\n+    w_bar = max(factor, round(w / factor) * factor)\n\n+    if h_bar * w_bar > max_pixels:\n\n+        beta = math.sqrt((h * w) / max_pixels)\n\n+        h_bar = max(factor, math.floor(h / beta / factor) * factor)\n\n+        w_bar = max(factor, math.floor(w / beta / factor) * factor)\n\n+    elif h_bar * w_bar < min_pixels:\n\n+        beta = math.sqrt(min_pixels / (h * w))\n\n+        h_bar = math.ceil(h * beta / factor) * factor\n\n+        w_bar = math.ceil(w * beta / factor) * factor\n\n+    return h_bar, w_bar\n\n+\n\n+\n\n+def parse_coords(text):\n\n+    \"\"\"Returns (bbox4, point2) in the *input* (resized) coord space, or (None, None).\"\"\"\n\n     text = text.strip()\n\n-    # Try JSON-like with bbox_2d\n\n     m = re.search(r'\"bbox_2d\"\\s*:\\s*\\[\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*\\]', text)\n\n     if m:\n\n         return [float(m.group(i)) for i in range(1,5)], None\n\n     m = re.search(r'\"point_2d\"\\s*:\\s*\\[\\s*([\\d.]+)\\s*,\\s*([\\d.]+)\\s*\\]', text)\n\n     if m:\n\n         return None, [float(m.group(1)), float(m.group(2))]\n\n-    # <box>x1 y1 x2 y2</box>\n\n+    m = re.search(r'<\\|box_start\\|>\\(?([\\d.]+)\\s*,\\s*([\\d.]+)\\)?[,\\s]+\\(?([\\d.]+)\\s*,\\s*([\\d.]+)\\)?<\\|box_end\\|>', text)\n\n+    if m:\n\n+        return [float(m.group(i)) for i in range(1,5)], None\n\n     m = re.search(r'<box>\\s*([\\d.]+)[\\s,]+([\\d.]+)[\\s,]+([\\d.]+)[\\s,]+([\\d.]+)\\s*</box>', text)\n\n     if m:\n\n         return [float(m.group(i)) for i in range(1,5)], None\n\n-    # generic 4-number tuple\n\n     nums = re.findall(r'-?\\d+\\.?\\d*', text)\n\n     if len(nums) >= 4:\n\n         return [float(x) for x in nums[:4]], None\n\n@@ -54,10 +71,10 @@\n     if not os.path.isdir(ckpt) or not os.path.exists(os.path.join(ckpt, 'config.json')):\n\n         ckpt = DEFAULT_MODEL_PATH\n\n \n\n+    MIN_PIX = 256*28*28\n\n+    MAX_PIX = 1280*28*28\n\n     processor = AutoProcessor.from_pretrained(\n\n-        ckpt,\n\n-        min_pixels=256*28*28,\n\n-        max_pixels=1280*28*28,\n\n+        ckpt, min_pixels=MIN_PIX, max_pixels=MAX_PIX,\n\n     )\n\n     model = Qwen2_5_VLForConditionalGeneration.from_pretrained(\n\n         ckpt, torch_dtype=torch.bfloat16, device_map='cuda:0'\n\n@@ -80,13 +97,18 @@\n             img = Image.open(img_path).convert('RGB')\n\n             if W is None: W = img.width\n\n             if H is None: H = img.height\n\n-        except Exception as e:\n\n+        except Exception:\n\n             preds.append({'id': row['id'], 'point': [0, 0]})\n\n             continue\n\n \n\n+        # Compute resized dims used by Qwen processor\n\n+        rh, rw = smart_resize(img.height, img.width, 28, MIN_PIX, MAX_PIX)\n\n+        sx = W / rw\n\n+        sy = H / rh\n\n+\n\n         text_query = (\n\n-            f\"Outline the position of the UI element described, and output the coordinates in JSON format. \"\n\n-            f\"Element: {instr}\"\n\n+            f\"Outline the position corresponding to the instruction by providing a bounding box in JSON format with key 