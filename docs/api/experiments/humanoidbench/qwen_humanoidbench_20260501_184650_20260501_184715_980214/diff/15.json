         ep_info_success = 0  # Track if info[\"success\"] was ever triggered\n\n                 \n\n@@ -61,6 +73,9 @@\n                     # Use deterministic=True for consistent evaluation\n\n                     action, _ = model.predict(obs, deterministic=True)\n\n                     obs, reward, terminated, truncated, info = env.step(action)\n\n+                    \n\n+                    # Pad the next observation\n\n+                    obs = pad_observation(obs)\n\n                     \n\n                     ep_reward += float(reward)\n\n                     \n\n@@ -122,16 +137,14 @@\n             \"n_episodes\": stats[\"episodes\"]\n\n         }\n\n     \n\n-    # Overall metrics\n\n-    total_success = sum(ep[\"success\"] for ep in per_episode)\n\n-    total_reward = sum(ep[\"reward\"] for ep in per_episode)\n\n-    overall_success_rate = total_success / len(per_episode) if per_episode else 0\n\n-    overall_mean_reward = total_reward / len(per_episode) if per_episode else 0\n\n+    # Prepare final results\n\n+    total_success_rate = sum(ep[\"success\"] for ep in per_episode) / len(per_episode) if per_episode else 0\n\n+    total_mean_reward = sum(ep[\"reward\"] for ep in per_episode) / len(per_episode) if per_episode else 0\n\n     \n\n     results = {\n\n-        \"success_rate\": overall_success_rate,\n\n-        \"mean_reward\": overall_mean_reward,\n\n-        \"total_episodes\": len(per_episode),\n\n+        \"success_rate\": total_success_rate,\n\n+        \"mean_reward\": total_mean_reward,\n\n+        \"total_episodes\": total_episodes,\n\n         \"per_task\": per_task_results,\n\n         \"per_episode\": per_episode\n\n     }\n\n@@ -139,6 +152,10 @@\n     # Write results to output file\n\n     with open(args.output, 'w') as f:\n\n         json.dump(results, f, indent=2)\n\n+    \n\n+    print(f\"Evaluation completed. Results saved to {args.output}\")\n\n+    print(f\"Overall success rate: {total_success_rate:.4f}\")\n\n+    print(f\"Overall mean reward: {total_mean_reward:.4f}\")\n\n \n\n if __name__ == \"__main__\":\n\n     main()"}]}