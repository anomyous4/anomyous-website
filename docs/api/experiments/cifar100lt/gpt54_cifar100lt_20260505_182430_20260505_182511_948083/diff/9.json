ilename":"predict.py","status":"modified","added_lines":29,"removed_lines":3,"diff":"--- a/predict.py\n+++ b/predict.py\n@@ -4,7 +4,9 @@\n \n\n import albumentations as A\n\n from albumentations.pytorch import ToTensorV2\n\n+import numpy as np\n\n import torch\n\n+from sklearn.metrics import balanced_accuracy_score\n\n from torch.utils.data import DataLoader, Dataset\n\n \n\n from model import build_model\n\n@@ -14,6 +16,7 @@\n     def __init__(self, pt_path, img_size):\n\n         data = torch.load(pt_path, map_location=\"cpu\")\n\n         self.images = data[\"images\"]\n\n+        self.labels = data.get(\"labels\")\n\n         self.transform = A.Compose([\n\n             A.Resize(img_size, img_size),\n\n             A.Normalize(mean=(0.485, 0.456, 0.406), std=(0.229, 0.224, 0.225)),\n\n@@ -26,7 +29,8 @@\n     def __getitem__(self, idx):\n\n         image = self.images[idx].permute(1, 2, 0).numpy()\n\n         image = self.transform(image=image)[\"image\"]\n\n-        return image\n\n+        label = -1 if self.labels is None else int(self.labels[idx])\n\n+        return image, label\n\n \n\n \n\n def resolve_pt_path(data_path: str) -> Path:\n\n@@ -81,6 +85,14 @@\n     return [load_single_model(checkpoint_path, device)]\n\n \n\n \n\n+def forward_tta(model, images, use_flip_tta=False):\n\n+    logits = model(images)\n\n+    if use_flip_tta:\n\n+        logits_flip = model(torch.flip(images, dims=[3]))\n\n+        logits = 0.5 * (logits + logits_flip)\n\n+    return logits\n\n+\n\n+\n\n def main():\n\n     parser = argparse.ArgumentParser()\n\n     parser.add_argument(\"--data_path\", type=str, required=True)\n\n@@ -88,6 +100,8 @@\n     parser.add_argument(\"--output\", type=str, required=True)\n\n     parser.add_argument(\"--batch_size\", type=int, default=128)\n\n     parser.add_argument(\"--num_workers\", type=int, default=4)\n\n+    parser.add_argument(\"--tta\", action=\"store_true\")\n\n+    parser.add_argument(\"--report_val\", action=\"store_true\")\n\n     args = parser.parse_args()\n\n \n\n     device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n\n@@ -111,21 +125,33 @@\n     loader = DataLoader(ds, batch_size=args.batch_size, shuffle=False, num_workers=args.num_workers, pin_memory=True)\n\n \n\n     preds = []\n\n+    labels = []\n\n     with torch.no_grad():\n\n-        for images in loader:\n\n+        for images, batch_labels in loader:\n\n             images = images.to(device, non_blocking=True)\n\n             logits_sum = None\n\n             for m, adjustment in zip(models, adjustments):\n\n-                logits = m[\"model\"](images)\n\n+                logits = forward_tta(m[\"model\"], images, use_flip_tta=args.tta)\n\n                 if adjustment is not None:\n\n                     logits = logits + adjustment.unsqueeze(0)\n\n                 logits_sum = logits if logits_sum is None else logits_sum + logits\n\n             pred = (logits_sum / len(models)).argmax(dim=1)\n\n             preds.extend(pred.cpu().tolist())\n\n+            labels.extend(batch_labels.tolist())\n\n \n\n     with open(args.output, \"w\") as f:\n\n         json.dump({\"predictions\": preds}, f)\n\n \n\n+    if args.report_val and any(x >= 0 for x in labels):\n\n+        y_true = np.array(labels)\n\n+        y_pred = np.array(preds)\n\n+        print({\n\n+            \"val_balanced_accuracy\": float(balanced_accuracy_score(y_true, y_pred)),\n\n+            \"n\": int(len(preds)),\n\n+            \"head\": preds[:5],\n\n+            \"tta\": bool(args.tta),\n\n+        })\n\n+\n\n \n\n if __name__ == \"__main__\":\n\n     main()\n"}]}