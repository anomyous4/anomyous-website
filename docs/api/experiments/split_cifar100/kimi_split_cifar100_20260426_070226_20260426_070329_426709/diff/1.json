{"iteration":1,"prev_iteration":0,"diffs":[{"filename":"model.py","status":"added","added_lines":19,"removed_lines":0,"diff":"--- a/model.py\n+++ b/model.py\n@@ -0,0 +1,19 @@\n+import torch\n\n+import torch.nn as nn\n\n+import torchvision.models as models\n\n+\n\n+class CIFAR100ResNet(nn.Module):\n\n+    def __init__(self, num_classes=100, pretrained=False):\n\n+        super().__init__()\n\n+        self.register_buffer('mean', torch.tensor([0.5071, 0.4867, 0.4408]).view(1, 3, 1, 1))\n\n+        self.register_buffer('std', torch.tensor([0.2675, 0.2565, 0.2761]).view(1, 3, 1, 1))\n\n+        self.model = models.resnet18(pretrained=pretrained)\n\n+        self.model.conv1 = nn.Conv2d(3, 64, kernel_size=3, stride=1, padding=1, bias=False)\n\n+        self.model.maxpool = nn.Identity()\n\n+        self.model.fc = nn.Linear(self.model.fc.in_features, num_classes)\n\n+\n\n+    def forward(self, x):\n\n+        if x.dtype == torch.uint8:\n\n+            x = x.float() / 255.0\n\n+        x = (x - self.mean) / self.std\n\n+        return self.model(x)\n"},{"filename":"predict.py","status":"added","added_lines":40,"removed_lines":0,"diff":"--- a/predict.py\n+++ b/predict.py\n@@ -0,0 +1,40 @@\n+import os\n\n+import json\n\n+import argparse\n\n+import torch\n\n+from torch.utils.data import TensorDataset, DataLoader\n\n+from model import CIFAR100ResNet\n\n+\n\n+def main():\n\n+    parser = argparse.ArgumentParser()\n\n+    parser.add_argument('--data_path', type=str, required=True)\n\n+    parser.add_argument('--checkpoint', type=str, required=True)\n\n+    parser.add_argument('--output', type=str, required=True)\n\n+    args = parser.parse_args()\n\n+\n\n+    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n\n+\n\n+    model = CIFAR100ResNet(num_classes=100).to(device)\n\n+    model.load_state_dict(torch.load(args.checkpoint, map_location=device))\n\n+    model.eval()\n\n+\n\n+    test_data = torch.load(os.path.join(args.data_path, 'test.pt'))\n\n+    tes