edict.py","status":"modified","added_lines":36,"removed_lines":27,"diff":"--- a/predict.py\n+++ b/predict.py\n@@ -33,7 +33,8 @@\n \n\n     SAFE_MIN = 1.0\n\n     SAFE_MAX = 2.0\n\n-    FACING_THRESH = 0.5  # radians; success usually requires |angle| < some threshold\n\n+    TARGET_DIST = 1.4\n\n+    FACING_THRESH = 0.5\n\n \n\n     NUM_EPISODES = 50\n\n \n\n@@ -45,39 +46,48 @@\n             obs = env.reset()\n\n             safe_follow_steps = 0\n\n             ep_id = env.current_episode.episode_id if hasattr(env, 'current_episode') else str(ep_idx)\n\n+\n\n+            prev_dist = None\n\n+            stuck_counter = 0\n\n+\n\n             while not env.episode_over:\n\n                 dist, angle = obs['agent_0_goal_to_agent_gps_compass']\n\n \n\n-                # Controller: angle convention from sanity check —\n\n-                # positive ang_vel made angle (which was negative) increase toward 0.\n\n-                # So to drive angle -> 0: turn = sign(angle) * k (positive ang_vel when angle<0 -> wait that's negative)\n\n-                # Re-deriving: angle was -1.406 -> -0.573 with ang_vel=+1. Angle increased.\n\n-                # So +ang_vel increases angle. To drive angle to 0 when angle<0, need +ang_vel (increase). Correct: turn = -sign(angle)? No.\n\n-                # If angle = -0.5 and we want angle->0, we need angle to increase (more positive). +ang_vel does that. So turn = +1 when angle<0.\n\n-                # That means turn = -sign(angle). Yes: angle=-0.5, sign=-1, turn = +1. Good.\n\n-                # If angle = +0.5, sign=+1, turn=-1, which decreases angle. Good.\n\n-                turn_cmd = -np.sign(angle) * min(1.0, abs(angle) * 2.0)\n\n+                # Turn to face human aggressively\n\n+                # Convention: +ang_vel makes angle increase (verified). So turn = -k*angle drives angle->0? No.\n\n+                # If angle = -0.5: -k*angle = +0.5*k -> +ang_vel -> angle increases toward 0. Good.\n\n+                # If angle = +0.5: -k*angle = -0.5*k -> -ang_vel -> angle decreases toward 0. Good.\n\n+                turn_cmd = float(np.clip(-angle * 3.0, -1.0, 1.0))\n\n \n\n-                # Forward speed: drive into safe band\n\n-                if abs(angle) > 0.6:\n\n-                    # not facing — turn first, no forward\n\n+                # Forward control: pursue when far, stay & follow when close\n\n+                # Always move forward proportional to (dist - TARGET_DIST), since human is moving\n\n+                if abs(angle) > 1.0:\n\n+                    # human nearly behind us, just turn\n\n                     lin = 0.0\n\n-                elif dist > SAFE_MAX:\n\n-                    lin = 1.0\n\n-                elif dist >= SAFE_MIN:\n\n-                    # in safe band — match human's motion. Stay still or slight forward to maintain.\n\n-                    # Distance is changing because human walks. Keep small forward proportional.\n\n-                    if dist > 1.7:\n\n-                        lin = 0.4\n\n-                    elif dist > 1.3:\n\n-                        lin = 0.1\n\n+                else:\n\n+                    # active pursuit. Cap at 1.\n\n+                    err = dist - TARGET_DIST\n\n+                    # gain — strong forward when far\n\n+                    lin = float(np.clip(err * 1.2, -0.5, 1.0))\n\n+                    # Reduce forward when angle is moderate\n\n+                    if abs(angle) > 0.4:\n\n+                        lin = lin * 0.3\n\n+\n\n+                # Stuck detection: if dist not decreasing while we want to approach\n\n+                if prev_dist is not None:\n\n+                    if dist > 2.5 and abs(dist - prev_dist) < 0.005:\n\n+                        stuck_counter += 1\n\n                     else:\n\n-                        lin = 0.0\n\n-                else:\n\n-                    # too close, back up\n\n+                        stuck_counter = max(0, stuck_counter - 1)\n\n+                prev_dist = dist\n\n+\n\n+                if stuck_counter > 15:\n\n+                    # back up + turn random\n\n                     lin = -0.5\n\n+                    turn_cmd = 1.0 if (ep_idx % 2 == 0) else -1.0\n\n+                    if stuck_counter > 30:\n\n+                        stuck_counter = 0\n\n \n\n-                # When we're in safe band & facing, count\n\n                 action = {\n\n                     'action': ('agent_0_base_velocity', 'agent_1_oracle_nav_randcoord_action'),\n\n                     'action_args': {\n\n@@ -87,7 +97,6 @@\n                 }\n\n                 obs = env.step(action)\n\n \n\n-                # Track safe follow steps — use post-step dist & angle\n\n                 d2, a2 = obs['agent_0_goal_to_agent_gps_compass']\n\n                 if SAFE_MIN <= d2 < SAFE_MAX and abs(a2) < FACING_THRESH:\n\n                     safe_follow_steps += 1\n"}]}