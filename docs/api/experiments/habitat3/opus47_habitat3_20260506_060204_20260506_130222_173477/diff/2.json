h = os.path.abspath(args.data_path)\n\n+    args.checkpoint = os.path.abspath(args.checkpoint)\n\n+    args.output = os.path.abspath(args.output)\n\n+\n\n+    os.chdir('/opt/habitat-lab-src')\n\n+\n\n+    import habitat\n\n+    from habitat.config.default import get_config\n\n+    from habitat.config import read_write\n\n+\n\n+    cfg_path = (\n\n+        '/opt/habitat-lab-src/habitat-lab/habitat/config/'\n\n+        'benchmark/multi_agent/hssd_spot_human_social_nav.yaml'\n\n+    )\n\n+    config = get_config(cfg_path)\n\n+    with read_write(config):\n\n+        config.habitat.simulator.scene_dataset = (\n\n+            '/opt/habitat-lab-src/data/hab3_bench_assets/hab3-hssd/'\n\n+            'hab3-hssd.scene_dataset_config.json'\n\n+        )\n\n+        config.habitat.dataset.scenes_dir = '/opt/habitat-lab-src/data/scene_datasets'\n\n+        config.habitat.dataset.split = 'val'\n\n+        config.habitat.seed = 42\n\n+\n\n+    SAFE_MIN = 1.0\n\n+    SAFE_MAX = 2.0\n\n+    FACING_THRESH = 0.5  # radians; success usually requires |angle| < some threshold\n\n+\n\n+    NUM_EPISODES = 50\n\n+\n\n+    per_episode = []\n\n+\n\n+    with habitat.Env(config=config) as env:\n\n+        env.seed(42)\n\n+        for ep_idx in range(NUM_EPISODES):\n\n+            obs = env.reset()\n\n+            safe_follow_steps = 0\n\n+            ep_id = env.current_episode.episode_id if hasattr(env, 'current_episode') else str(ep_idx)\n\n+            while not env.episode_over:\n\n+                dist, angle = obs['agent_0_goal_to_agent_gps_compass']\n\n+\n\n+                # Controller: angle convention from sanity check —\n\n+                # positive ang_vel made angle (which was negative) increase toward 0.\n\n+                # So to drive angle -> 0: turn = sign(angle) * k (positive ang_vel when angle<0 -> wait that's negative)\n\n+                # Re-deriving: angle was -1.406 -> -0.573 with ang_vel=+1. Angle increased.\n\n+                # So +ang_vel increases angle. To drive angle to 0 when angle<0, need +ang_vel (increase). Correct: turn = -sign(angle)? No.\n\n+                # If angle = -0.5 and we want angle->0, we need angle to increase (more positive). +ang_vel does that. So turn = +1 when angle<0.\n\n+                # That means turn = -sign(angle). Yes: angle=-0.5, sign=-1, turn = +1. Good.\n\n+                # If angle = +0.5, sign=+1, turn=-1, which decreases angle. Good.\n\n+                turn_cmd = -np.sign(angle) * min(1.0, abs(angle) * 2.0)\n\n+\n\n+                # Forward speed: drive into safe band\n\n+                if abs(angle) > 0.6:\n\n+                    # not facing — turn first, no forward\n\n+                    lin = 0.0\n\n+                elif dist > SAFE_MAX:\n\n+                    lin = 1.0\n\n+                elif dist >= SAFE_MIN:\n\n+                    # in safe band — match human's motion. Stay still or slight forward to maintain.\n\n+                    # Distance is changing because human walks. Keep small forward proportional.\n\n+                    if dist > 1.7:\n\n+                        lin = 0.4\n\n+                    elif dist > 1.3:\n\n+                        lin = 0.1\n\n+                    else:\n\n+                        lin = 0.0\n\n+                else:\n\n+                    # too close, back up\n\n+                    lin = -0.5\n\n+\n\n+                # When we're in safe band & facing, count\n\n+                action = {\n\n+                    'action': ('agent_0_base_velocity', 'agent_1_oracle_nav_randcoord_action'),\n\n+                    'action_args': {\n\n+                        'agent_0_base_vel': np.array([lin, turn_cmd], dtype=np.float32),\n\n+                        'agent_1_oracle_nav_randcoord_action': np.array([1.0], dtype=np.float32),\n\n+                    },\n\n+                }\n\n+                obs = env.step(action)\n\n+\n\n+                # Track safe follow steps — use post-step dist & angle\n\n+                d2, a2 = obs['agent_0_goal_to_agent_gps_compass']\n\n+                if SAFE_MIN <= d2 < SAFE_MAX and abs(a2) < FACING_THRESH:\n\n+                    safe_follow_steps += 1\n\n+\n\n+            metrics = env.get_metrics()\n\n+            stats = metrics.get('social_nav_stats', {})\n\n+            success = 1 if safe_follow_steps >= 500 else 0\n\n+            per_episode.append({\n\n+                'episode_id': str(ep_id),\n\n+                'nav_seek_success': success,\n\n+                'social_nav_reward': float(metrics.get('social_nav_reward', 0.0)),\n\n+                'found_human_rate_over_epi': float(stats.get('found_human_rate_over_epi', 0.0)),\n\n+                'safe_follow_steps': int(safe_follow_steps),\n\n+                'avg_robot_to_human_dis_over_epi': float(stats.get('avg_robot_to_human_dis_over_epi', 0.0)),\n\n+                'nav_to_pos_success': int(bool(metrics.get('nav_to_pos_success', 0))),\n\n+            })\n\n+            print(f'EP {ep_idx} id={ep_id}: safe_steps={safe_follow_steps} success={success} reward={metrics.get(\"social_nav_reward\",0):.2f}', flush=True)\n\n+\n\n+    def avg(k):\n\n+        return sum(e[k] for e in per_episode) / max(1, len(per_episode))\n\n+    out = {\n\n+        'primary_metric': 'nav_seek_success',\n\n+        'nav_seek_success': avg('nav_seek_success'),\n\n+        'social_nav_reward': avg('social_nav_reward'),\n\n+        'found_human_rate_over_epi': avg('found_human_rate_over_epi'),\n\n+        'safe_follow_steps': avg('safe_follow_steps'),\n\n+        'avg_robot_to_human_dis_over_epi': avg('avg_robot_to_human_dis_over_epi'),\n\n+        'nav_to_pos_success': avg('nav_to_pos_success'),\n\n+        'per_episode': per_episode,\n\n+        'total_episodes': len(per_episode),\n\n+    }\n\n+    with open(args.output, 'w') as f:\n\n+        json.dump(out, f, indent=2)\n\n+    print('WROTE', args.output)\n\n+    print('SUMMARY:', {k: out[k] for k in ['nav_seek_success', 'social_nav_reward', 'safe_follow_steps']})\n\n+\n\n+if __name__ == '__main__':\n\n+    main()\n"}]}