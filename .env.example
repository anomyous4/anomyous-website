# FARBench environment variables
# Copy to .env and fill in your values:  cp .env.example .env
# docker compose automatically loads .env.

# Timeout for long-running task preparation steps such as large dataset downloads.
# Increase this for tasks like VLABench that may need hours to prepare.
FARBENCH_PREPARE_TIMEOUT_SECONDS=14400

# GPUs available to FARBench (comma-separated physical GPU IDs).
# Leave empty to allow all GPUs.
FARBENCH_GPUS=0,1

# CUDA variant for task image archive loading.
# Must be one of: cu118, cu128.
# cu118 (default) uses nvidia/cuda:11.8.0; cu128 uses nvidia/cuda:12.8.1.
# Read by: docker-compose.yml, cli/main.py, scripts/run.sh, scripts/dev/clean.sh.
FARBENCH_CUDA=cu118


# Google Custom Search (used by agent sandbox for web search)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_google_cse_id_here


# ── Agent presets ──────────────────────────────────────────
# Use with: farbench run --preset claude  (or gpt4o, gemini, ...)
# API keys are required. BASE_URL/MODEL have code defaults in farbench/llm/providers.py;
# set them here only when you need to override the release preset.

# Claude Sonnet 4.6 (Anthropic)
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com/v1
CLAUDE_MODEL=claude-sonnet-4-6

# Claude Opus 4.6 (Anthropic)
# OPUS46_API_KEY=
# OPUS46_BASE_URL=https://api.anthropic.com/v1
# OPUS46_MODEL=claude-opus-4-6

# Claude Opus 4.7 (Anthropic; temperature omitted automatically)
# OPUS47_API_KEY=
# OPUS47_BASE_URL=https://api.anthropic.com/v1
# OPUS47_MODEL=claude-opus-4-7

# GPT-4o (OpenAI)
GPT4O_API_KEY=
GPT4O_BASE_URL=https://api.openai.com/v1
GPT4O_MODEL=gpt-4o

# GPT-5.4 (OpenAI reasoning; requires max_completion_tokens — handled automatically)
# GPT54_API_KEY=
# GPT54_BASE_URL=https://api.openai.com/v1
# GPT54_MODEL=gpt-5.4

# GPT-5.5 (OpenAI reasoning; max_completion_tokens and temperature=1 handled automatically)
# GPT55_API_KEY=
# GPT55_BASE_URL=https://api.openai.com/v1
# GPT55_MODEL=gpt-5.5

# Gemini (Google, via OpenAI-compatible endpoint)
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-3.1-pro-preview

# GLM (Zhipu / Z.AI)
# GLM_API_KEY=
# GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# GLM_MODEL=glm-5.1

# Qwen (Alibaba DashScope)
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3-coder-plus-2025-09-23

# Kimi (Moonshot)
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.6

# Grok (xAI)
# GROK_API_KEY=
# GROK_BASE_URL=https://api.x.ai/v1
# GROK_MODEL=grok-4.20-0309-reasoning

# DeepSeek V4-Pro (text-only — no multimodal input)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-v4-pro

# ── Add your own presets ─────────────────────────────────
# Any OpenAI-compatible endpoint works. Use the naming convention:
#   {PRESET}_API_KEY / {PRESET}_BASE_URL / {PRESET}_MODEL
# base_url must include the version prefix (e.g. /v1). Then run:
#   bash scripts/run.sh --preset <preset> --task <task>

# Hugging Face (used by task preparation and agent sandbox downloads)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
# Optional transfer acceleration for supported environments
# HF_HUB_ENABLE_HF_TRANSFER=1

# Public FARBench runs load published task images. Task-specific build-time
# dataset variables are intentionally not part of the release runtime config.
